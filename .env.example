# =============================================================================
# .env.example — Chat Memory System
#
# USAGE:
#   cp .env.example .env
#   Fill in every value marked <REPLACE_ME> with your real credentials.
#   Never commit .env — it is in .gitignore.
#
# LOCAL DEV (no cloud accounts needed for Postgres/Redis):
#   docker compose -f docker-compose.dev.yml up
# =============================================================================

# =============================================================================
# Database — PostgreSQL with pgvector
# =============================================================================
# Connection string for async Postgres via asyncpg.
# The docker-compose.dev.yml stack exposes Postgres on port 5432.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/memory_system

# =============================================================================
# Redis — session memory, caching
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# LLM Providers
# =============================================================================
# OpenAI — primary provider for extraction, evaluation, embeddings
OPENAI_API_KEY=<REPLACE_ME>

# Anthropic — secondary provider for response generation
ANTHROPIC_API_KEY=<REPLACE_ME>

# Embedding model (default: text-embedding-3-small, 1536 dimensions)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# =============================================================================
# Application
# =============================================================================
APP_ENV=development
LOG_LEVEL=INFO

# Maximum memories stored per user before compression is triggered
MAX_MEMORIES_PER_USER=10000

# =============================================================================
# Retrieval Weights (sum to 1.0)
# =============================================================================
SEMANTIC_WEIGHT=0.4
RECENCY_WEIGHT=0.2
FREQUENCY_WEIGHT=0.2
IMPORTANCE_WEIGHT=0.2
RETRIEVAL_TOP_K=10

# =============================================================================
# Decay Settings
# =============================================================================
DECAY_FACTOR=0.95
ARCHIVE_THRESHOLD=0.1
DECAY_SCHEDULE_HOURS=24

# =============================================================================
# API Authentication (Phase 0-9: simple header-based)
# =============================================================================
API_KEY=dev-api-key-change-in-production
